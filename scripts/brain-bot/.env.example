# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Bot Owner (your Telegram user ID, integer)
OWNER_TELEGRAM_ID=123456789

# Telegram Group with Forum Topics enabled (group chat ID, negative integer)
GROUP_CHAT_ID=-1001234567890

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Notion Integration (optional)
NOTION_TOKEN=ntn_your-token

# Gemini API (primary, recommended: upgrade to paid tier for ~$0.15/day)
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# Classifier (optional, defaults shown)
CLASSIFIER_LLM_MODEL=claude-haiku-4-5-20251001
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# Daily token budget (0 = unlimited, set to limit spending on free tier)
DAILY_TOKEN_BUDGET=0

# Langfuse observability (optional)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-your-key
LANGFUSE_SECRET_KEY=sk-lf-your-key
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
